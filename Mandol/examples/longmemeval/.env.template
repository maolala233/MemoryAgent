# LongMemEval example environment variable template
# Copy this file to .env and fill in actual values

# ===================
# LLM API Configuration
# ===================
OPENAI_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_S=60

# ===================
# Embedding Model Configuration (remote mode, optional)
# ===================
# EMBEDDING_BASE_URL=http://localhost:8000/v1
# EMBEDDING_API_PATH=/embeddings
# EMBEDDER_MODEL=Qwen/Qwen3-Embedding-4B
# EMBEDDER_DIM=2560

# ===================
# Reranker Model Configuration (remote mode, optional)
# ===================
# RERANKER_BASE_URL=https://your-reranker-api-endpoint.com
# RERANKER_API_PATH=/v1/rerank
# RERANKER_MODEL=Qwen/Qwen3-Reranker-4B

# ===================
# Local Model Device
# ===================
EMBEDDER_DEVICE=cpu
RERANKER_DEVICE=cpu

# ===================
# Dataset Path
# ===================
DATASET_PATH=data/longmemeval_example.json
