# Memory System Environment Configuration Template
# Copy this file to .env and fill in your actual values

# ===================
# Embedder (Docker) #
# ===================
# Base URL for the embedding model Docker service
EMBEDDING_BASE_URL=http://localhost:8000/v1
# API path for embeddings
EMBEDDING_API_PATH=/embeddings
# Environment variable name that holds the API key
EMBEDDING_TOKEN_ENV=OPENAI_API_KEY
# Embedder model name
EMBEDDER_MODEL=Qwen/Qwen3-Embedding-4B
# Embedder dimension
EMBEDDER_DIM=2560
# Embedder timeout in seconds
EMBEDDING_TIMEOUT_S=30

# ===================
# Reranker (Remote API) #
# ===================
# Base URL for the reranker API
RERANKER_BASE_URL=https://your-reranker-api-endpoint.com
# API path for reranking
RERANKER_API_PATH=/v1/rerank
# Environment variable name that holds the API key
RERANKER_TOKEN_ENV=OPENAI_API_KEY
# Reranker model name
RERANKER_MODEL=Qwen/Qwen3-Reranker-4B
# Reranker timeout in seconds
RERANKER_TIMEOUT_S=30

# ===================
# LLM (Remote API) #
# ===================
# Base URL for the LLM API
LLM_BASE_URL=https://api.openai.com/v1
# Environment variable name that holds the API key
LLM_API_KEY_ENV=OPENAI_API_KEY
# LLM model name
LLM_MODEL=gpt-4o-mini
# LLM timeout in seconds
LLM_TIMEOUT_S=60

# ===================
# Memory System Settings #
# ===================
# Dataset path
DATASET_PATH=/path/to/locomo10.json
# Number of samples to process (set to 1 for single example test)
SAMPLE_COUNT=1
# Embedder device (cpu, cuda, npu)
EMBEDDER_DEVICE=cpu
# Reranker device (cpu, cuda, npu)
RERANKER_DEVICE=cpu
# Chunk max tokens
CHUNK_MAX_TOKENS=512
# Session time gap in seconds
SESSION_TIME_GAP_SECONDS=1800
# Similarity top k
SIMILARITY_TOP_K=5
# Similarity threshold
SIMILARITY_THRESHOLD=0.7
# Similarity recent window
SIMILARITY_RECENT_WINDOW=20
# BFS expansion per seed
BFS_EXPANSION_PER_SEED=3
# BFS expansion hops
BFS_EXPANSION_HOPS=1
# Progress report interval
PROGRESS_REPORT_INTERVAL=1
