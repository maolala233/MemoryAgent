# ===== LLM (OpenAI-compatible) =====
# MANDOL_LLM_API_KEY=sk-your-api-key-here
# MANDOL_LLM_BASE_URL=https://api.openai.com/v1
# MANDOL_LLM_MODEL=gpt-4o-mini
# MANDOL_LLM_TIMEOUT_S=60

# ===== Remote Embedder =====
# MANDOL_EMBEDDER_API_KEY=
# MANDOL_EMBEDDER_BASE_URL=http://localhost:8000/v1
# MANDOL_EMBEDDER_API_PATH=/embeddings
# MANDOL_EMBEDDER_MODEL=Qwen/Qwen3-Embedding-4B
# USE_REMOTE_EMBEDDER=false

# ===== Remote Reranker =====
# MANDOL_RERANKER_API_KEY=
# MANDOL_RERANKER_BASE_URL=https://your-reranker-api-endpoint.com
# MANDOL_RERANKER_API_PATH=/rerank
# MANDOL_RERANKER_MODEL=Qwen/Qwen3-Reranker-4B
# USE_REMOTE_RERANKER=false

# ===== Neo4j (optional GraphStore) =====
# MANDOL_NEO4J_URI=bolt://localhost:7687
# MANDOL_NEO4J_USER=neo4j
# MANDOL_NEO4J_PASSWORD=neo4j
# MANDOL_NEO4J_DATABASE=neo4j

# ===== Milvus (optional UnitStore) =====
# MANDOL_MILVUS_URI=http://localhost:19530
# MANDOL_MILVUS_USER=
# MANDOL_MILVUS_PASSWORD=
# MANDOL_MILVUS_DB=
# MANDOL_MILVUS_COLLECTION=mandol_memory_units
