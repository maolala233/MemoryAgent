# Codex Memory environment configuration
# Copy to .env and adjust as needed.

# ---- Storage ----
VAULT_DIR=data/vault
DB_PATH=data/codex_memory.db
UPLOAD_DIR=data/uploads

# ---- Server ----
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# ---- Logging ----
# 日志文件输出目录(不存在会自动创建);为空则只输出到 stderr
LOG_DIR=data/logs
# 单个日志文件最大字节数,超过则滚动;默认 50MB
LOG_MAX_BYTES=52428800
# 日志保留天数,超过则自动清理;默认 7 天
LOG_RETENTION_DAYS=7
# 滚动时保留的备份文件数(防止磁盘被写满);默认 20
LOG_BACKUP_COUNT=20

# ---- Faiss ----
# 关闭 faiss loader 对 AVX2/AVX512 优化包装层的探测(当前 wheel 不带 swigfaiss_avx2/avx512 子模块,
# 否则会在日志里出现 No module named 'faiss.swigfaiss_avx2' 的噪音,实际功能不受影响)。
# 设为 generic / avx2 / avx512 之一;留空则由 faiss 按 CPU 自动选
FAISS_OPT_LEVEL=generic

# ---- LLM provider (mock | ollama | openai) ----
DEFAULT_LLM_PROVIDER=mock
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---- Embeddings (mock | ollama | openai) ----
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIM=384

# ---- Cache ----
ENABLE_CACHE=true
CACHE_TTL_SEARCH=300
CACHE_TTL_STATS=1800

# ===================================================
# Mandol MemorySystem
# ===================================================
MANDOL_ENABLED=true
MANDOL_STORAGE_DIR=data/mandol
MANDOL_LLM_MODEL=gemma4:12b
MANDOL_LLM_BASE_URL=http://localhost:11434/v1
MANDOL_LLM_API_KEY=ollama

# ---- Embedder / Reranker ----
# 远端默认模型名
MANDOL_EMBEDDER_MODEL=sentence-transformers/all-MiniLM-L6-v2
MANDOL_EMBEDDER_DEVICE=cpu
MANDOL_EMBEDDER_DIM=384
# 已下载到本地的 embedder 目录（优先于远端模型名加载）
MANDOL_EMBEDDER_LOCAL_PATH=
MANDOL_EMBEDDER_OFFLINE_ONLY=false

MANDOL_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
MANDOL_RERANKER_DEVICE=cpu
MANDOL_RERANKER_LOCAL_PATH=
MANDOL_RERANKER_OFFLINE_ONLY=false

# ---- HuggingFace 缓存 ----
HF_HOME=
HF_ENDPOINT=https://hf-mirror.com
HF_OFFLINE=false

# ---- Neo4j 图数据库 ----
MANDOL_NEO4J_URI=bolt://localhost:7687
MANDOL_NEO4J_USER=neo4j
MANDOL_NEO4J_PASSWORD=mandol123
MANDOL_NEO4J_DATABASE=neo4j

# ---- 远程 Milvus 向量数据库（用于 Mandol 记忆单元存储）----
MANDOL_MILVUS_REMOTE_ENABLED=true
MANDOL_MILVUS_URI=http://localhost:19530
MANDOL_MILVUS_USER=
MANDOL_MILVUS_PASSWORD=
MANDOL_MILVUS_DB=
MANDOL_MILVUS_TOKEN=
MANDOL_MILVUS_SECURE=false
MANDOL_MILVUS_COLLECTION=mandol_memory_units

# ---- 远程 Milvus 用于应用配置/缓存 ----
APP_MILVUS_REMOTE_ENABLED=true
APP_MILVUS_URI=http://localhost:19530
APP_MILVUS_USER=
APP_MILVUS_PASSWORD=
APP_MILVUS_DB=
APP_MILVUS_TOKEN=
APP_MILVUS_SECURE=false
APP_MILVUS_CONFIG_COLLECTION=codex_config
APP_MILVUS_CACHE_COLLECTION=codex_cache
